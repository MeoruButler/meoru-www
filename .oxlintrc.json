{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "plugins": ["react", "react-perf", "typescript", "unicorn", "import", "jsx-a11y"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "style": "off",
    "pedantic": "off"
  },
  "env": {
    "browser": true,
    "es2024": true,
    "node": true
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.output/**",
    "**/.nitro/**",
    "**/.turbo/**",
    "**/.tanstack/**",
    "**/.vinxi/**",
    "**/coverage/**",
    "**/routeTree.gen.ts"
  ],
  "rules": {
    "no-unused-vars": "off",
    "typescript/no-unused-vars": "off",
    "react/react-in-jsx-scope": "off"
  }
}
