{
  "name": "meoru-www",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "start": "turbo start",
    "lint": "oxlint && turbo lint",
    "lint:fix": "oxlint --fix && turbo lint:fix",
    "lint:oxc": "oxlint",
    "format": "turbo format",
    "format:check": "prettier --check . && turbo format:check",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "clean": "turbo clean && rm -rf node_modules/.cache .turbo"
  },
  "devDependencies": {
    "oxlint": "^1.62.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.7",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  }
}
